# Beefree CSAPI key — used to authenticate against api.getbee.io
BEE_API_KEY=your_csapi_key_here

# Beefree API base URL (no trailing slash)
BEE_API_BASE=https://api.getbee.io

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | google
# Default model pairs are automatically selected per provider:
#   anthropic → claude-sonnet-4-6 (main) + claude-haiku-4-5 (fast)
#   openai    → gpt-4o (main) + gpt-4o-mini (fast)
#   google    → gemini-2.5-flash (main) + gemini-2.5-flash (fast)
AI_PROVIDER=anthropic

# ── Provider API keys ─────────────────────────────────────────────────────────
# Uncomment and fill in the key for your chosen provider.
# PydanticAI reads these standard env vars automatically.

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI
# OPENAI_API_KEY=your_openai_key_here

# Google (Gemini via Google AI Studio)
# GOOGLE_API_KEY=your_google_ai_key_here

# ── Optional model overrides ──────────────────────────────────────────────────
# Override individual model strings if you want a specific model instead of
# the provider defaults above. Use PydanticAI model strings:
#   anthropic:claude-sonnet-4-6
#   openai:gpt-4o
#   google-gla:gemini-2.0-flash
#
# LLM_MODEL=
# LLM_PLANNER_MODEL=
# LLM_LAYOUT_MODEL=
# LLM_EXECUTOR_MODEL=
