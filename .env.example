# Beefree CSAPI key — used to authenticate against api.getbee.io
BEE_API_KEY=your_csapi_key_here

# Beefree API base URL (no trailing slash)
BEE_API_BASE=https://api.getbee.io

# PydanticAI model string — swap to any supported provider:
#   anthropic:claude-sonnet-4-6
#   openai:gpt-4o
#   google-gla:gemini-2.0-flash
#   groq:llama-3.3-70b-versatile
#   mistral:mistral-large-latest
LLM_MODEL=anthropic:claude-sonnet-4-6

# API key for the chosen LLM provider
# For Anthropic:  ANTHROPIC_API_KEY
# For OpenAI:     OPENAI_API_KEY
# PydanticAI reads provider-specific env vars automatically,
# but you can also set LLM_API_KEY as a generic override.
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
